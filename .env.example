# === Gmail ===
# Use an App Password, not your regular account password.
# To create one: Google Account > Security > 2-Step Verification > App Passwords
GMAIL_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# === Google Sheets ===
# Exact name of the spreadsheet as it appears in Google Drive
GOOGLE_SHEET_NAME=Your_Sheet_Name

# === Flask ===
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
PORT=5001

# === App Login ===
APP_USERNAME=laboratorio
APP_PASSWORD=change-this-password

# === Optional: SMTP override (defaults to Gmail) ===
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# === Optional: Brevo API (for production, replaces SMTP) ===
# BREVO_API_KEY=your-brevo-api-key

# === Optional: Google credentials as JSON (for cloud deployment) ===
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
